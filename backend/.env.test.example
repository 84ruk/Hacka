# Copiar a .env.test. Usado por: npm run test:e2e y npm run test:db:migrate
# El script test:e2e carga este archivo con dotenv-cli y exige NODE_ENV=test + DATABASE_URL_TEST.
# Así no se usa la base de datos de desarrollo en e2e.

# Obligatorio en test (fail-fast si falta). Debe apuntar a la BD de test (p. ej. Docker en 5434).
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5434/auth_db_test?schema=public

# JWT para tests (prioridad *_TEST; si no está se usa JWT_SECRET del entorno)
JWT_SECRET_TEST=secret-for-test-only-min-32-chars

# --- BD de test en Docker (reproducible) ---
# 1. Levantar: npm run test:db:up   (docker-compose.test.yml, puerto 5434)
# 2. Migrar:   npm run test:db:migrate
# 3. E2E:      npm run test:e2e
# 4. Bajar:    npm run test:db:down  (opcional)
