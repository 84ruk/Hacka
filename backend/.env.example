# Obligatorio: conexión PostgreSQL
# Docker (docker compose up -d): puerto 5433
# Postgres local: normalmente 5432
DATABASE_URL="postgresql://USER:PASSWORD@localhost:PORT/DBNAME?schema=public"

# JWT (obligatorio para auth)
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Opcionales (convención: backend 3001, frontend Next en 3000)
PORT=3001
NODE_ENV=development
# Recuperación de contraseña (Fase 7)
RESET_TOKEN_EXPIRATION_MINUTES=60
# RESET_PASSWORD_BASE_URL=http://localhost:3000

# Cookies (auth por cookies httpOnly)
# COOKIE_SAME_SITE=lax | strict | none
# COOKIE_SECURE=true | false  (en producción debería ser true)

# Ejemplo con Docker:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/auth_db?schema=public"
# Ejemplo Postgres local:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db?schema=public"
