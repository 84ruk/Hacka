# Copiar a .env.e2e para tests Playwright. No versionar .env.e2e (credenciales).
# La app debe estar corriendo con NEXT_PUBLIC_API_BASE_URL apuntando al backend (ej. http://localhost:3001).

# URL del frontend donde corren los e2e (por defecto 3000)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Admin del seed del backend (backend/prisma/seed.ts: admin@example.com)
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=Admin123!
